# ─────────────────────────────────────────────────────────────────────────────
# Trove — environment. Copy to `.env.local` for dev, or set in your host's env.
# Trove ALWAYS runs. With a Qwen Cloud key it thinks on Qwen; without one it uses a
# clearly-labelled local offline brain. The memory ENGINE (owned store, budgeted recall,
# reconciliation, forgetting, the numbers) is identical and fully real in BOTH modes.
# NEVER commit real keys — this repo is published.
# ─────────────────────────────────────────────────────────────────────────────

# The load-bearing brain: Qwen Cloud (Alibaba Cloud Model Studio). Plain `sk-` key.
# Get one (no card) at https://home.qwencloud.com/api-keys
DASHSCOPE_API_KEY=

# Base URL for the OpenAI-compatible surface (chat, embeddings, images).
# Default is the international (Singapore) endpoint, which pairs with a plain sk- key.
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# The DashScope text-rerank service (note: /api/v1, a different path than compatible-mode).
QWEN_RERANK_URL=https://dashscope-intl.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank

# Model IDs (override only if you know why). Split by capability per Qwen's own docs:
#  - biographer  : the interviewer/narrator (long-horizon, tool loop) — no structured output
#  - listener    : typed structured extraction + vision (photo of an old picture)
#  - reconciler  : cross-telling contradiction detection / consolidation (cheap, full-feature)
#  - embed/rerank: budgeted vector recall
#  - image       : the seed-locked portrait (optional live enhancement; the mosaic is real without it)
TROVE_BIOGRAPHER_MODEL=qwen3.7-max
TROVE_LISTENER_MODEL=qwen3.7-plus
TROVE_RECONCILER_MODEL=qwen3.6-flash
TROVE_EMBED_MODEL=text-embedding-v4
TROVE_RERANK_MODEL=qwen3-rerank
TROVE_IMAGE_MODEL=wan2.6-t2i
TROVE_ASR_MODEL=qwen3-asr-flash

# Hard per-question recall budget (tokens). The counter on every ask is live from this.
TROVE_TOKEN_BUDGET=4096

# Durable store for serverless / multi-instance deploys (e.g. Alibaba Cloud RDS, Neon).
# Leave EMPTY to use the owned file store (one JSON bundle per trove, survives restarts).
DATABASE_URL=

# Where the file store writes when DATABASE_URL is unset. Defaults to ./.trove-data
# TROVE_DATA_DIR=./.trove-data
